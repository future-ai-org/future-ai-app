# Supabase (PostgreSQL)
# Get these from: Supabase Dashboard → Project Settings → Database
# Use Transaction mode (port 6543) + pgbouncer for the app; use Session/Direct (port 5432) for migrations.

# App runtime: Supavisor transaction pooler (required for serverless / Vercel)
DATABASE_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrations only: direct or session pooler (Prisma migrate uses this via prisma.config.ts)
# If your password has @ # % / : etc., URL-encode it (e.g. @ → %40, # → %23) or you'll get P1013.
DIRECT_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Auth (NextAuth). Generate with: npx auth secret
AUTH_SECRET=

# Base URL for auth callbacks. Required for OAuth (e.g. Google). Use your app URL including port if not 3000.
# Local: http://localhost:8066   Production: https://yourdomain.com
AUTH_URL=

# OAuth (optional). Create apps at:
# Google: https://console.cloud.google.com/apis/credentials
# GitHub: https://github.com/settings/developers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
