    "@vitest/coverage-v8": "^2.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.6"
